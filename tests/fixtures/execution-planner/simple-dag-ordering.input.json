          "mode": "orchestrate",
          "lastOutput": { "summary": "ok" }
        }
      },
      {
        "id": "view_brief",
        "type": "view",
        "data": {
          "outputTemplate": "brief_card",
          "lastOutput": { "rendered": true }
        }
      }
